# Copie a .env o ejecute: .\scripts\detect-ports.ps1
# Puertos por defecto (bloque dedicado Clinica ERP, evita conflictos habituales)

POSTGRES_USER=clinica
POSTGRES_PASSWORD=clinica_secret
POSTGRES_DB=clinica_erp
# 5432/5433 suelen estar ocupados (WAMP, Docker)
POSTGRES_PORT=5434

# 6379 suele estar ocupado (Redis local / otros contenedores)
REDIS_PORT=6380

# 3000/3030 suelen usarse por otras apps Node
API_PORT=3050
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
OTP_TTL_SECONDS=300
CORS_ORIGIN=http://localhost:3010

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@clinica.local

HR_API_URL=http://localhost:3999/mock/hr
HR_API_KEY=dev-key
HR_USE_MOCK=true
HIS_WEBHOOK_SECRET=dev-his-secret

# Integraciones salientes al ERP principal
INTEGRATION_SECRET_KEY=
ERP_USE_MOCK=true

# Desarrollo: omitir JWT/RBAC (no usar en producción)
AUTH_DISABLED=true
NUXT_PUBLIC_AUTH_DISABLED=true

# Impresora Zebra (TCP raw, puerto 9100)
ZEBRA_HOST=127.0.0.1
ZEBRA_PORT=9100

FRONTEND_PORT=3010
# Desarrollo: usar proxy Nuxt (sin CORS). Producción: URL completa de la API.
NUXT_PUBLIC_API_BASE=/api/v1
NUXT_API_PROXY=http://127.0.0.1:3050

DATABASE_URL=postgresql://clinica:clinica_secret@localhost:5434/clinica_erp
REDIS_URL=redis://localhost:6380
