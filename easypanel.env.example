# Variables para desplegar en Easypanel (2 servicios: API + Frontend)
# PostgreSQL ya migrado en easypanel.clinicamaicao.com

# ─── Servicio 1: API (backend/) ───
# Dockerfile: backend/Dockerfile
# Puerto contenedor: 3000

NODE_ENV=production
PORT=3000
DATABASE_URL=postgres://postgres:CAMBIAR@easypanel.clinicamaicao.com:5434/clinica_erp?sslmode=disable
REDIS_URL=redis://redis:6379
JWT_SECRET=generar_cadena_larga_aleatoria
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
OTP_TTL_SECONDS=300
AUTH_DISABLED=false
NUXT_PUBLIC_AUTH_DISABLED=false
CORS_ORIGIN=https://TU-FRONTEND.clinicamaicao.com
INTEGRATION_SECRET_KEY=generar_clave_para_tokens_integraciones

# ─── Servicio 2: Frontend (frontend/) ───
# Dockerfile: frontend/Dockerfile
# Puerto contenedor: 3000

# URL interna del servicio API en Easypanel (nombre del servicio + puerto 3000)
NUXT_API_PROXY=http://NOMBRE-SERVICIO-API:3000
NUXT_PUBLIC_API_BASE=/api/v1
NUXT_PUBLIC_AUTH_DISABLED=false
